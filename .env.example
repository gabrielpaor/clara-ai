# ── PostgreSQL ────────────────────────────────────────────────
# One Postgres container serves two databases:
#   - invoice_clerk : our application data (Prisma + pgvector)
#   - n8n           : n8n's own internal storage (workflows, executions)
POSTGRES_USER=clerk
POSTGRES_PASSWORD=change-me
POSTGRES_DB=invoice_clerk

# ── n8n ───────────────────────────────────────────────────────
# Encrypts credentials n8n stores (API keys, OAuth tokens).
# Generate once, never change it afterwards or stored credentials break.
N8N_ENCRYPTION_KEY=change-me-32-random-chars

# Timezone used by schedule triggers (cron) inside n8n
GENERIC_TIMEZONE=Asia/Manila

# ── OpenAI (added in Phase 2) ─────────────────────────────────
# OPENAI_API_KEY=sk-...

// Data model for Clara — AI Accounts-Payable employee.
//
// Design principles:
//  - Invoice.status is a strict state machine; transitions only happen
//    through code that also writes an AuditLog row.
//  - Money is Decimal, never Float (floats can't represent 0.1 exactly).
//  - The raw LLM output is preserved verbatim in Invoice.extraction (Json)
//    even after fields are promoted to typed columns — audit + debugging.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────

/// Invoice lifecycle. RECEIVED → EXTRACTING → NEEDS_REVIEW → APPROVED
/// → SCHEDULED → PAID, with REJECTED / FAILED as exits. High-confidence,
/// low-amount invoices may skip NEEDS_REVIEW (auto-approval).
enum InvoiceStatus {
  RECEIVED
  EXTRACTING
  NEEDS_REVIEW
  APPROVED
  REJECTED
  SCHEDULED
  PAID
  FAILED
}

enum InvoiceSource {
  EMAIL
  UPLOAD
}

/// Who performed an audited action — the core of the compliance story.
enum ActorType {
  AI
  HUMAN
  SYSTEM
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum UserRole {
  ADMIN
  REVIEWER
}

// ── Models ───────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(REVIEWER)
  createdAt    DateTime   @default(now())
  auditEntries AuditLog[]
}

/// Master data: the companies that send us invoices. Extraction matches
/// the vendor name on the document against this table; unknown vendors
/// are themselves a review reason.
model Vendor {
  id        String    @id @default(cuid())
  name      String
  email     String?   @unique
  taxId     String?   @unique
  iban      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  invoices  Invoice[]
}

model Invoice {
  id     String        @id @default(cuid())
  status InvoiceStatus @default(RECEIVED)
  source InvoiceSource

  // Original document
  fileName    String
  mimeType    String
  storagePath String // local disk for now; same column works for S3 keys later
  /// External origin id — for EMAIL invoices, the Gmail message id. Used to
  /// skip re-ingesting a message the poller has already delivered.
  sourceRef   String?

  // Extracted fields — all nullable: they don't exist until extraction succeeds
  vendorId      String?
  vendor        Vendor?   @relation(fields: [vendorId], references: [id])
  vendorNameRaw String? // vendor name exactly as printed on the document
  invoiceNumber String?
  invoiceDate   DateTime?
  dueDate       DateTime?
  currency      String?   @db.Char(3)
  subtotal      Decimal?  @db.Decimal(12, 2)
  tax           Decimal?  @db.Decimal(12, 2)
  total         Decimal?  @db.Decimal(12, 2)

  // AI metadata
  extraction Json? /// raw LLM output, kept verbatim
  confidence Float? /// 0–1 overall extraction confidence
  flags      String[] /// rule violations, e.g. "TOTALS_MISMATCH", "UNKNOWN_VENDOR"

  /// Embedding of the canonical invoice text (vendor|number|date|total),
  /// used for near-duplicate detection via cosine similarity. Prisma has
  /// no native vector type, so reads/writes go through raw SQL.
  embedding Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLog AuditLog[]
  runs     WorkflowRun[]

  // Same vendor + same invoice number = duplicate. NULLs are exempt in
  // Postgres, so unextracted invoices don't collide.
  @@unique([vendorId, invoiceNumber])
  @@index([status])
  @@index([createdAt])
  @@index([sourceRef])
}

/// Append-only. Every state transition and every decision (AI or human)
/// writes one row. Never updated, never deleted.
model AuditLog {
  id         String         @id @default(cuid())
  invoiceId  String
  invoice    Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  actor      ActorType
  userId     String?
  user       User?          @relation(fields: [userId], references: [id])
  action     String // e.g. "EXTRACTION_COMPLETED", "STATUS_CHANGED", "APPROVED"
  fromStatus InvoiceStatus?
  toStatus   InvoiceStatus?
  reason     String? // human-readable: "confidence 0.62 below threshold 0.85"
  metadata   Json?
  createdAt  DateTime       @default(now())

  @@index([invoiceId, createdAt])
}

/// One row per n8n workflow execution — our observability bridge.
/// n8n reports start/finish/failure here so the dashboard can show
/// automation health without opening the n8n UI.
model WorkflowRun {
  id             String    @id @default(cuid())
  workflowName   String
  n8nExecutionId String?
  invoiceId      String?
  invoice        Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  status         RunStatus @default(RUNNING)
  error          String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@index([workflowName, startedAt])
}
